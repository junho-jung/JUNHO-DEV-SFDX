<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Custom Rich Text Container</masterLabel>
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <property
                    name="objectApiName"
                    type="String"
                    label="Object API Name"
            />
            <property
                    name="fieldApiNames"
                    type="String"
                    label="Field API Names (comma or semicolon separated)"
            />
            <property
                    name="sectionLabel"
                    type="String"
                    label="Section Label"
            />
            <property
                    name="isOpen"
                    type="Boolean"
                    label="Open Section by Default"
                    default="false"
            />
            <property
                    name="hideChildSaveButtons"
                    type="Boolean"
                    label="Hide Child Save Buttons"
                    default="true"
            />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>