        // =========================================================
        // ✅ postMessage 리스너: 부모 LWC에서 에디터 HTML 요청 수신
        // =========================================================
        window.addEventListener('message', function(event) {
          var data = event.data;
          if (!data || typeof data !== 'object') return;

          if (data.type === 'REQUEST_EDITOR_HTML') {
            var html = getEditorHtml();
            parent.postMessage({
              type: 'RESPONSE_EDITOR_HTML',
              requestId: data.requestId,
              html: html
            }, event.origin);
          }
        });

        // ✅ 폴링 없이 instanceReady에서만 초기값 세팅
        (function initDefaultValue() {
          const defaultHtml = '{!JSENCODE(richTextHtml)}';
      const ed = findEditorInstance();
      if (!ed) return;

      const applyOnce = function() {
        if (defaultHtml) {
          ed.setData(defaultHtml);
        }
        console.log('=== Default RichText Applied ===');
        console.log(defaultHtml);
      };

      if (ed.status === 'ready') {
        applyOnce();
      } else {
        ed.on('instanceReady', applyOnce);
      }
    })();
