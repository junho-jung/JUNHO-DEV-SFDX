    <script>
        function findEditorInstance() {
          try {
            const ta = document.querySelector('textarea[id$="richText"]');
            const id = ta ? ta.id : null;
            if (id && window.CKEDITOR && CKEDITOR.instances && CKEDITOR.instances[id]) {
              return CKEDITOR.instances[id];
            }
          } catch (e) {}
          if (window.CKEDITOR && CKEDITOR.instances) {
            for (const k in CKEDITOR.instances) return CKEDITOR.instances[k];
          }
          return null;
        }

        function getEditorHtml() {
          const ed = findEditorInstance();
          if (ed) return ed.getData();

          const ta = document.querySelector('textarea[id$="richText"]');
          return ta ? ta.value : '';
        }

